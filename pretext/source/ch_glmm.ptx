                <cell>Major City</cell><cell>1.00</cell><cell></cell><cell><m>\lt 0.01</m></cell>
              </row>
              <row>
                <cell>Inner Regional</cell><cell>1.16</cell><cell>1.04–1.28</cell><cell></cell>
              </row>
