<?xml version='1.0' encoding='utf-8'?>
<!-- This is the main file of the pretext template book provided -->
<!-- by the <c>pretext new book</c> command.  The main.ptx here always-->
<!-- starts with <pretext> tags.  In this example, the main file -->
<!-- just imports other .ptx files which contain content. Open   -->
<!-- those files to see more pretext features                    -->

<pretext xml:lang="en-US" xmlns:xi="http://www.w3.org/2001/XInclude">

  <!-- we first include a file which contains the docinfo element: -->
  <xi:include href="./meta_docinfo.ptx" />

  <!-- The <book> tags wrap all the content.  Change the @xml:id   -->
  <!-- to some short (non-spaced) description of your book         -->
  <book xml:id="beyond-mlr">
    <!-- The book needs a title and can have a subtitle  -->
    <title>Beyond Multiple Linear Regression</title>
    <subtitle>Applied Generalized Linear Models and Multilevel Models in R</subtitle>

    <!-- Now we include files containing each main devision.       -->

    <!-- First a frontmatter for prefaces and such. -->
    <xi:include href="./meta_frontmatter.ptx" />

    <!-- Chapter 1: Review of Multiple Linear Regression -->
    <xi:include href="./ch_intro.ptx" />

    <!-- Chapter 2: Beyond Least Squares: Using Likelihoods -->
    <xi:include href="./ch_beyond_least_squares.ptx" />

    <!-- Chapter 3: Distribution Theory -->
    <xi:include href="./ch_distribution_theory.ptx" />

    <!-- Chapter 4: Poisson Regression -->
    <xi:include href="./ch_poisson_regression.ptx" />

    <!-- Chapter 5: Generalized Linear Models: A Unifying Theory -->
    <xi:include href="./ch_glms.ptx" />

    <!-- Chapter 6: Logistic Regression -->
    <xi:include href="./ch_logistic_regression.ptx" />

    <!-- Chapter 7: Correlated Data -->
    <xi:include href="./ch_correlated_data.ptx" />

    <!-- Chapter 8: Introduction to Multilevel Models -->
    <xi:include href="./ch_multilevel_intro.ptx" />

    <!-- Chapter 9: Two-Level Longitudinal Data -->
    <xi:include href="./ch_longitudinal.ptx" />

    <!-- Chapter 10: Multilevel Data With More Than Two Levels -->
    <xi:include href="./ch_3level.ptx" />

    <!-- Chapter 11: Multilevel Generalized Linear Models -->
    <xi:include href="./ch_glmm.ptx" />

    <!-- Finally we place the backmatter in its own file and include-->
    <xi:include href="./meta_backmatter.ptx" />
  </book>
</pretext>
